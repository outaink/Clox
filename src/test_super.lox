class Doughnut {
  cook() {
    print "Dunk in the fryer.";
  }
}

class Cruller < Doughnut {
  finish() {
    print "Glaze with icing";
  }
}

class A {
  method() {
    print "A method";
  }
}

class B < A {
  method() {
    print "B method";
  }

  test() {
    super.method();
  }
}

class C < B {}

print "--- Inheritance Simple ---";
var cruller = Cruller();
cruller.cook();
cruller.finish();

print "--- Inheritance Super Call ---";
C().test();
